{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "if": "Write(*.manifest.json)",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/runtime/validate-manifest.mjs\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/runtime/env-check.mjs\""
          }
        ]
      }
    ]
  }
}
