{
  "schemaVersion": 1,
  "screen": "InventoryScreen",
  "refResolution": [1920, 1080],
  "elements": [
    {
      "key": "panel.inventory",
      "name": "Panel_Inventory",
      "component": "Panel_Base",
      "anchor": "stretch",
      "margin": [16, 16, 16, 16],
      "layout": "vertical",
      "spacing": 12,
      "children": [
        {
          "key": "panel.inventory.header",
          "name": "Panel_Header",
          "component": "Panel_Base",
          "anchor": "top",
          "height": 60,
          "layout": "horizontal",
          "spacing": 8,
          "children": [
            {
              "key": "panel.inventory.header.title",
              "name": "Text_Title",
              "component": "Text_Base",
              "label": "인벤토리"
            }
          ]
        },
        {
          "key": "panel.inventory.scroll",
          "name": "ScrollView_Items",
          "component": "ScrollList",
          "anchor": "stretch",
          "scroll": "vertical",
          "children": [
            {
              "key": "panel.inventory.scroll.grid",
              "name": "Grid_Items",
              "component": "Grid_Base",
              "layout": "grid",
              "spacing": 8,
              "repeat": 40,
              "children": [
                {
                  "key": "panel.inventory.scroll.grid.slot",
                  "name": "ItemSlot_Base",
                  "component": "ItemSlot",
                  "width": 80,
                  "height": 80,
                  "iconSlot": "item_icon"
                }
              ]
            }
          ]
        },
        {
          "key": "panel.inventory.footer",
          "name": "Panel_Footer",
          "component": "Panel_Base",
          "anchor": "bottom",
          "height": 80,
          "layout": "horizontal",
          "spacing": 12,
          "children": [
            {
              "key": "panel.inventory.footer.equip",
              "name": "Btn_Equip",
              "component": "Btn_Base",
              "label": "장착",
              "width": 120,
              "height": 48
            },
            {
              "key": "panel.inventory.footer.drop",
              "name": "Btn_Drop",
              "component": "Btn_Base",
              "label": "버리기",
              "width": 120,
              "height": 48
            }
          ]
        }
      ]
    }
  ]
}
