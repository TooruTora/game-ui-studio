{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://game-ui-studio.dev/schema/manifest.schema.json",
  "title": "Game UI Studio UI Manifest",
  "description": "중립 레이아웃 표현. 웹 프리뷰와 Unity UGUI 두 소비자의 공통 언어. 순수 레이아웃/구조만 표현하며 상호작용(bindTo 등) 필드는 두지 않는다.",
  "type": "object",
  "required": ["screen", "refResolution", "elements"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "description": "매니페스트 스키마 버전. 마이그레이션 판정용.",
      "minimum": 1,
      "default": 1
    },
    "screen": {
      "type": "string",
      "description": "화면 프리팹 이름 (PascalCase 권장, 예: RosterScreen)",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
    },
    "refResolution": {
      "type": "array",
      "description": "CanvasScaler 레퍼런스 해상도 [width, height]",
      "items": { "type": "integer", "minimum": 1 },
      "minItems": 2,
      "maxItems": 2
    },
    "elements": {
      "type": "array",
      "description": "최상위 element 목록",
      "items": { "$ref": "#/definitions/element" }
    }
  },
  "definitions": {
    "element": {
      "type": "object",
      "required": ["key", "name", "component"],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "description": "안정 식별자. 재조립 시 add/update/remove 매칭 기준. ManagedMarker.stableKey에 박힘.",
          "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)*$"
        },
        "name": {
          "type": "string",
          "description": "Unity GameObject 이름 (네이밍 규약 준수, 예: Panel_Roster)",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
        },
        "component": {
          "type": "string",
          "description": "카탈로그 부품 ID. 카탈로그에 등재된 것만 허용 (검증 hook이 차단).",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
        },
        "anchor": {
          "type": "string",
          "description": "추상 앵커 프리셋",
          "enum": ["stretch", "top", "bottom", "left", "right", "center", "top-left", "top-right", "bottom-left", "bottom-right"]
        },
        "margin": {
          "type": "array",
          "description": "여백 [left, top, right, bottom]",
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        },
        "layout": {
          "type": "string",
          "description": "레이아웃 그룹 종류",
          "enum": ["vertical", "horizontal", "grid", "none"]
        },
        "spacing": {
          "type": "number",
          "description": "레이아웃 그룹 간격",
          "minimum": 0
        },
        "columns": {
          "type": "integer",
          "description": "grid 레이아웃의 열 개수 (layout=grid일 때 사용)",
          "minimum": 1
        },
        "width": { "type": "number", "minimum": 0, "description": "고정 폭 (선택)" },
        "height": { "type": "number", "minimum": 0, "description": "고정 높이 (선택)" },
        "label": { "type": "string", "description": "부품 오버라이드: 텍스트 라벨" },
        "iconSlot": { "type": "string", "description": "부품 오버라이드: 아이콘 슬롯 ID" },
        "scroll": {
          "type": "string",
          "description": "스크롤 방향 (ScrollList/ScrollView 계열). R3 표현력 항목.",
          "enum": ["vertical", "horizontal", "both", "none"]
        },
        "repeat": {
          "description": "동적 반복 리스트 (R3 표현력 항목). 정수 N 또는 데이터 바인딩 키. 항목 템플릿은 children[0]을 사용.",
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "description": "런타임 데이터 소스 식별자 (구조 표현용, 거동은 코드)" }
          ]
        },
        "children": {
          "type": "array",
          "description": "자식 element. repeat가 설정되면 children[0]이 반복 템플릿.",
          "items": { "$ref": "#/definitions/element" }
        }
      }
    }
  }
}
